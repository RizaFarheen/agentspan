{
  "description": "Agent workflow for support_agent",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "support_agent",
  "outputParameters": {
    "finishReason": "${support_agent_llm.output.finishReason}",
    "result": "${support_agent_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.support_agent_loop['iteration'] < 25 && $.support_agent_llm['finishReason'] != 'LENGTH' && ($.support_agent_llm['toolCalls'] != null && $.support_agent_llm['toolCalls'].length > 0) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a customer support agent. Use the available tools to look up customers, check inventory, process orders, and format responses for the customer.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "temperature": 0,
            "tools": [
              {
                "description": "Format a data dictionary into a human-readable string.",
                "inputSchema": {
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  },
                  "required": [
                    "data"
                  ],
                  "type": "object"
                },
                "name": "format_response",
                "outputSchema": {
                  "type": "string"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Look up customer details from the CRM system.",
                "inputSchema": {
                  "properties": {
                    "customer_id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "customer_id"
                  ],
                  "type": "object"
                },
                "name": "get_customer",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Check product availability in a warehouse.",
                "inputSchema": {
                  "properties": {
                    "product_id": {
                      "type": "string"
                    },
                    "warehouse": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "product_id"
                  ],
                  "type": "object"
                },
                "name": "check_inventory",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Process a customer order. Actions: refund, cancel, update.",
                "inputSchema": {
                  "properties": {
                    "action": {
                      "type": "string"
                    },
                    "order_id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "order_id",
                    "action"
                  ],
                  "type": "object"
                },
                "name": "process_order",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              }
            ]
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "support_agent_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "decisionCases": {
            "tool_call": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                  "toolCalls": "${support_agent_llm.output.toolCalls}"
                },
                "name": "support_agent_enrich_tools",
                "taskReferenceName": "support_agent_enrich_tools",
                "type": "INLINE"
              },
              {
                "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                "dynamicForkTasksParam": "dynamicTasks",
                "inputParameters": {
                  "dynamicTasks": "${support_agent_enrich_tools.output.result.dynamicTasks}",
                  "dynamicTasksInputs": {}
                },
                "name": "support_agent_fork",
                "taskReferenceName": "support_agent_fork",
                "type": "FORK_JOIN_DYNAMIC"
              },
              {
                "inputParameters": {},
                "name": "support_agent_fork_join",
                "taskReferenceName": "support_agent_fork_join",
                "type": "JOIN"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "graaljs",
          "expression": "$.toolCalls != null && $.toolCalls.length > 0 ? 'tool_call' : 'none'",
          "inputParameters": {
            "toolCalls": "${support_agent_llm.output.toolCalls}"
          },
          "name": "support_agent_tool_router",
          "taskReferenceName": "support_agent_tool_router",
          "type": "SWITCH"
        }
      ],
      "name": "support_agent_loop",
      "taskReferenceName": "support_agent_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}