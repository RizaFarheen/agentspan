{
  "description": "Parallel agents: analysis",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "analysis",
  "outputParameters": {
    "result": {
      "compliance": "${analysis_parallel_2_compliance.output.result}",
      "market_analyst": "${analysis_parallel_0_market_analyst.output.result}",
      "risk_analyst": "${analysis_parallel_1_risk_analyst.output.result}"
    }
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "forkTasks": [
        [
          {
            "inputParameters": {
              "media": "${workflow.input.media}",
              "prompt": "${workflow.input.prompt}"
            },
            "name": "analysis_parallel_0_market_analyst",
            "subWorkflowParam": {
              "name": "market_analyst",
              "version": 1,
              "workflowDefinition": {
                "description": "Agent workflow for market_analyst",
                "enforceSchema": false,
                "failureWorkflow": "",
                "inputParameters": [
                  "prompt",
                  "session_id",
                  "media"
                ],
                "inputTemplate": {},
                "name": "market_analyst",
                "outputParameters": {
                  "finishReason": "${market_analyst_llm.output.finishReason}",
                  "result": "${market_analyst_llm.output.result}"
                },
                "schemaVersion": 2,
                "tasks": [
                  {
                    "inputParameters": {
                      "llmProvider": "openai",
                      "messages": [
                        {
                          "message": "You are a market analyst. Analyze the given topic from a market perspective: market size, growth trends, key players, and opportunities.",
                          "role": "system"
                        },
                        {
                          "media": "${workflow.input.media}",
                          "message": "${workflow.input.prompt}",
                          "role": "user"
                        }
                      ],
                      "model": "gpt-5-mini"
                    },
                    "name": "llm_chat_complete",
                    "taskReferenceName": "market_analyst_llm",
                    "type": "LLM_CHAT_COMPLETE"
                  }
                ],
                "timeoutSeconds": 60,
                "variables": {},
                "version": 1,
                "workflowStatusListenerEnabled": false
              }
            },
            "taskReferenceName": "analysis_parallel_0_market_analyst",
            "type": "SUB_WORKFLOW"
          }
        ],
        [
          {
            "inputParameters": {
              "media": "${workflow.input.media}",
              "prompt": "${workflow.input.prompt}"
            },
            "name": "analysis_parallel_1_risk_analyst",
            "subWorkflowParam": {
              "name": "risk_analyst",
              "version": 1,
              "workflowDefinition": {
                "description": "Agent workflow for risk_analyst",
                "enforceSchema": false,
                "failureWorkflow": "",
                "inputParameters": [
                  "prompt",
                  "session_id",
                  "media"
                ],
                "inputTemplate": {},
                "name": "risk_analyst",
                "outputParameters": {
                  "finishReason": "${risk_analyst_llm.output.finishReason}",
                  "result": "${risk_analyst_llm.output.result}"
                },
                "schemaVersion": 2,
                "tasks": [
                  {
                    "inputParameters": {
                      "llmProvider": "openai",
                      "messages": [
                        {
                          "message": "You are a risk analyst. Analyze the given topic for risks: regulatory risks, technical risks, competitive threats, and mitigation strategies.",
                          "role": "system"
                        },
                        {
                          "media": "${workflow.input.media}",
                          "message": "${workflow.input.prompt}",
                          "role": "user"
                        }
                      ],
                      "model": "gpt-5-mini"
                    },
                    "name": "llm_chat_complete",
                    "taskReferenceName": "risk_analyst_llm",
                    "type": "LLM_CHAT_COMPLETE"
                  }
                ],
                "timeoutSeconds": 60,
                "variables": {},
                "version": 1,
                "workflowStatusListenerEnabled": false
              }
            },
            "taskReferenceName": "analysis_parallel_1_risk_analyst",
            "type": "SUB_WORKFLOW"
          }
        ],
        [
          {
            "inputParameters": {
              "media": "${workflow.input.media}",
              "prompt": "${workflow.input.prompt}"
            },
            "name": "analysis_parallel_2_compliance",
            "subWorkflowParam": {
              "name": "compliance",
              "version": 1,
              "workflowDefinition": {
                "description": "Agent workflow for compliance",
                "enforceSchema": false,
                "failureWorkflow": "",
                "inputParameters": [
                  "prompt",
                  "session_id",
                  "media"
                ],
                "inputTemplate": {},
                "name": "compliance",
                "outputParameters": {
                  "finishReason": "${compliance_llm.output.finishReason}",
                  "result": "${compliance_llm.output.result}"
                },
                "schemaVersion": 2,
                "tasks": [
                  {
                    "inputParameters": {
                      "llmProvider": "openai",
                      "messages": [
                        {
                          "message": "You are a compliance specialist. Check the given topic for compliance considerations: data privacy, regulatory requirements, and industry standards.",
                          "role": "system"
                        },
                        {
                          "media": "${workflow.input.media}",
                          "message": "${workflow.input.prompt}",
                          "role": "user"
                        }
                      ],
                      "model": "gpt-5-mini"
                    },
                    "name": "llm_chat_complete",
                    "taskReferenceName": "compliance_llm",
                    "type": "LLM_CHAT_COMPLETE"
                  }
                ],
                "timeoutSeconds": 60,
                "variables": {},
                "version": 1,
                "workflowStatusListenerEnabled": false
              }
            },
            "taskReferenceName": "analysis_parallel_2_compliance",
            "type": "SUB_WORKFLOW"
          }
        ]
      ],
      "inputParameters": {},
      "joinOn": [
        "analysis_parallel_0_market_analyst",
        "analysis_parallel_1_risk_analyst",
        "analysis_parallel_2_compliance"
      ],
      "name": "analysis_fork",
      "taskReferenceName": "analysis_fork",
      "type": "FORK_JOIN"
    },
    {
      "inputParameters": {},
      "joinOn": [
        "analysis_parallel_0_market_analyst",
        "analysis_parallel_1_risk_analyst",
        "analysis_parallel_2_compliance"
      ],
      "name": "analysis_fork_join",
      "taskReferenceName": "analysis_fork_join",
      "type": "JOIN"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}