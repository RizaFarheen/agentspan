{
  "description": "Sequential pipeline: describer_storyteller",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "describer_storyteller",
  "outputParameters": {
    "result": "${describer_storyteller_step_1_storyteller.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "Describe the image in 2-3 vivid sentences.",
            "role": "system"
          },
          {
            "media": "${workflow.input.media}",
            "message": "${workflow.input.prompt}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "describer_storyteller_step_0_describer",
      "type": "LLM_CHAT_COMPLETE"
    },
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "You receive an image description. Write a short creative story (3-4 sentences) inspired by it.",
            "role": "system"
          },
          {
            "message": "${describer_storyteller_step_0_describer.output.result}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "describer_storyteller_step_1_storyteller",
      "type": "LLM_CHAT_COMPLETE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}