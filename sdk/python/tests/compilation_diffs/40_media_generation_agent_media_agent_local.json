{
  "description": "Agent workflow for media_generator",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "media_generator",
  "outputParameters": {
    "finishReason": "${media_generator_llm.output.finishReason}",
    "result": "${media_generator_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.media_generator_loop['iteration'] < 25 && $.media_generator_llm['finishReason'] != 'LENGTH' && ($.media_generator_llm['toolCalls'] != null && $.media_generator_llm['toolCalls'].length > 0) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a creative media generation assistant. You can generate:\n\n1. **Images** \u2014 from text descriptions using DALL-E 3.\n2. **Audio** \u2014 text-to-speech using OpenAI TTS (voices: alloy, echo, fable, onyx, nova, shimmer).\n3. **Video** \u2014 short video clips from text using OpenAI Sora.\n\nIMPORTANT: Image prompts MUST be under 950 characters.\nCall the appropriate tool once and present the result.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "temperature": 0,
            "tools": [
              {
                "description": "Generate an image from a text description using DALL-E 3.",
                "inputSchema": {
                  "properties": {
                    "height": {
                      "default": 1024,
                      "description": "Image height in pixels.",
                      "type": "integer"
                    },
                    "n": {
                      "default": 1,
                      "description": "Number of images to generate.",
                      "type": "integer"
                    },
                    "outputFormat": {
                      "default": "png",
                      "description": "Output format: 'png', 'jpg', or 'webp'.",
                      "type": "string"
                    },
                    "prompt": {
                      "description": "Text description of the image to generate.",
                      "type": "string"
                    },
                    "size": {
                      "description": "Image size (e.g. '1024x1024'). Alternative to width/height.",
                      "type": "string"
                    },
                    "style": {
                      "description": "Image style: 'vivid' or 'natural'.",
                      "type": "string"
                    },
                    "weight": {
                      "description": "Image weight parameter.",
                      "type": "number"
                    },
                    "width": {
                      "default": 1024,
                      "description": "Image width in pixels.",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "prompt"
                  ],
                  "type": "object"
                },
                "name": "generate_image",
                "type": "GENERATE_IMAGE"
              },
              {
                "description": "Convert text to natural-sounding speech audio using OpenAI TTS.",
                "inputSchema": {
                  "properties": {
                    "n": {
                      "default": 1,
                      "description": "Number of audio outputs to generate.",
                      "type": "integer"
                    },
                    "responseFormat": {
                      "default": "mp3",
                      "description": "Audio format: 'mp3', 'wav', 'opus', 'aac', or 'flac'.",
                      "type": "string"
                    },
                    "speed": {
                      "default": 1.0,
                      "description": "Speech speed multiplier (0.25 to 4.0).",
                      "type": "number"
                    },
                    "text": {
                      "description": "Text to convert to speech.",
                      "type": "string"
                    },
                    "voice": {
                      "default": "alloy",
                      "description": "Voice to use.",
                      "enum": [
                        "alloy",
                        "echo",
                        "fable",
                        "onyx",
                        "nova",
                        "shimmer"
                      ],
                      "type": "string"
                    }
                  },
                  "required": [
                    "text"
                  ],
                  "type": "object"
                },
                "name": "text_to_speech",
                "type": "GENERATE_AUDIO"
              },
              {
                "description": "Generate a short video clip from a text description using OpenAI Sora.",
                "inputSchema": {
                  "properties": {
                    "aspectRatio": {
                      "description": "Aspect ratio (e.g. '16:9', '1:1').",
                      "type": "string"
                    },
                    "duration": {
                      "default": 5,
                      "description": "Video duration in seconds.",
                      "type": "integer"
                    },
                    "fps": {
                      "default": 24,
                      "description": "Frames per second.",
                      "type": "integer"
                    },
                    "generateAudio": {
                      "description": "Whether to generate audio with the video.",
                      "type": "boolean"
                    },
                    "guidanceScale": {
                      "description": "Prompt adherence strength (1.0 to 20.0).",
                      "type": "number"
                    },
                    "height": {
                      "default": 720,
                      "description": "Video height in pixels.",
                      "type": "integer"
                    },
                    "inputImage": {
                      "description": "Base64-encoded or URL image for image-to-video generation.",
                      "type": "string"
                    },
                    "maxCostDollars": {
                      "description": "Maximum cost limit in dollars.",
                      "type": "number"
                    },
                    "maxDurationSeconds": {
                      "description": "Maximum duration ceiling in seconds.",
                      "type": "integer"
                    },
                    "motion": {
                      "description": "Movement intensity (e.g. 'slow', 'normal', 'extreme').",
                      "type": "string"
                    },
                    "n": {
                      "default": 1,
                      "description": "Number of videos to generate.",
                      "type": "integer"
                    },
                    "negativePrompt": {
                      "description": "Description of what to exclude from the video.",
                      "type": "string"
                    },
                    "outputFormat": {
                      "default": "mp4",
                      "description": "Video format (e.g. 'mp4').",
                      "type": "string"
                    },
                    "personGeneration": {
                      "description": "Controls for human figure generation.",
                      "type": "string"
                    },
                    "prompt": {
                      "description": "Text description of the video scene.",
                      "type": "string"
                    },
                    "resolution": {
                      "description": "Quality level (e.g. '720p', '1080p').",
                      "type": "string"
                    },
                    "seed": {
                      "description": "Seed for reproducibility.",
                      "type": "integer"
                    },
                    "size": {
                      "description": "Video size specification (e.g. '1280x720').",
                      "type": "string"
                    },
                    "style": {
                      "description": "Video style (e.g. 'cinematic', 'natural').",
                      "type": "string"
                    },
                    "width": {
                      "default": 1280,
                      "description": "Video width in pixels.",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "prompt"
                  ],
                  "type": "object"
                },
                "name": "generate_video",
                "type": "GENERATE_VIDEO"
              }
            ]
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "media_generator_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "decisionCases": {
            "tool_call": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {\"generate_image\": {\"taskType\": \"GENERATE_IMAGE\", \"defaults\": {\"llmProvider\": \"openai\", \"model\": \"dall-e-3\"}}, \"text_to_speech\": {\"taskType\": \"GENERATE_AUDIO\", \"defaults\": {\"llmProvider\": \"openai\", \"model\": \"tts-1\"}}, \"generate_video\": {\"taskType\": \"GENERATE_VIDEO\", \"defaults\": {\"llmProvider\": \"openai\", \"model\": \"sora-2\", \"size\": \"1280x720\", \"n\": 1}}};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                  "toolCalls": "${media_generator_llm.output.toolCalls}"
                },
                "name": "media_generator_enrich_tools",
                "taskReferenceName": "media_generator_enrich_tools",
                "type": "INLINE"
              },
              {
                "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                "dynamicForkTasksParam": "dynamicTasks",
                "inputParameters": {
                  "dynamicTasks": "${media_generator_enrich_tools.output.result.dynamicTasks}",
                  "dynamicTasksInputs": {}
                },
                "name": "media_generator_fork",
                "taskReferenceName": "media_generator_fork",
                "type": "FORK_JOIN_DYNAMIC"
              },
              {
                "inputParameters": {},
                "name": "media_generator_fork_join",
                "taskReferenceName": "media_generator_fork_join",
                "type": "JOIN"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "graaljs",
          "expression": "$.toolCalls != null && $.toolCalls.length > 0 ? 'tool_call' : 'none'",
          "inputParameters": {
            "toolCalls": "${media_generator_llm.output.toolCalls}"
          },
          "name": "media_generator_tool_router",
          "taskReferenceName": "media_generator_tool_router",
          "type": "SWITCH"
        }
      ],
      "name": "media_generator_loop",
      "taskReferenceName": "media_generator_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}