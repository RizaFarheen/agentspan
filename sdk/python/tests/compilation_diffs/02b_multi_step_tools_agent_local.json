{
  "description": "Agent workflow for account_analyst",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "account_analyst",
  "outputParameters": {
    "finishReason": "${account_analyst_llm.output.finishReason}",
    "result": "${account_analyst_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.account_analyst_loop['iteration'] < 25 && $.account_analyst_llm['finishReason'] != 'LENGTH' && ($.account_analyst_llm['toolCalls'] != null && $.account_analyst_llm['toolCalls'].length > 0) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are an account analyst. When asked about a customer, look them up, fetch their transactions, calculate the total, and provide a summary. Use the tools step by step.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "temperature": 0,
            "tools": [
              {
                "description": "Look up a customer by email address.",
                "inputSchema": {
                  "properties": {
                    "email": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "email"
                  ],
                  "type": "object"
                },
                "name": "lookup_customer",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Get recent transactions for a customer.",
                "inputSchema": {
                  "properties": {
                    "customer_id": {
                      "type": "string"
                    },
                    "limit": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "customer_id",
                    "limit"
                  ],
                  "type": "object"
                },
                "name": "get_transactions",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Calculate the sum of a list of amounts.",
                "inputSchema": {
                  "properties": {
                    "amounts": {
                      "items": {
                        "type": "number"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "amounts"
                  ],
                  "type": "object"
                },
                "name": "calculate_total",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Send a summary email to a customer.",
                "inputSchema": {
                  "properties": {
                    "body": {
                      "type": "string"
                    },
                    "subject": {
                      "type": "string"
                    },
                    "to": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "to",
                    "subject",
                    "body"
                  ],
                  "type": "object"
                },
                "name": "send_summary_email",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              }
            ]
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "account_analyst_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "decisionCases": {
            "tool_call": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                  "toolCalls": "${account_analyst_llm.output.toolCalls}"
                },
                "name": "account_analyst_enrich_tools",
                "taskReferenceName": "account_analyst_enrich_tools",
                "type": "INLINE"
              },
              {
                "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                "dynamicForkTasksParam": "dynamicTasks",
                "inputParameters": {
                  "dynamicTasks": "${account_analyst_enrich_tools.output.result.dynamicTasks}",
                  "dynamicTasksInputs": {}
                },
                "name": "account_analyst_fork",
                "taskReferenceName": "account_analyst_fork",
                "type": "FORK_JOIN_DYNAMIC"
              },
              {
                "inputParameters": {},
                "name": "account_analyst_fork_join",
                "taskReferenceName": "account_analyst_fork_join",
                "type": "JOIN"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "graaljs",
          "expression": "$.toolCalls != null && $.toolCalls.length > 0 ? 'tool_call' : 'none'",
          "inputParameters": {
            "toolCalls": "${account_analyst_llm.output.toolCalls}"
          },
          "name": "account_analyst_tool_router",
          "taskReferenceName": "account_analyst_tool_router",
          "type": "SWITCH"
        }
      ],
      "name": "account_analyst_loop",
      "taskReferenceName": "account_analyst_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}