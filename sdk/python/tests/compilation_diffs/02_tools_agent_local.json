{
  "description": "Agent workflow for tool_demo_agent",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "tool_demo_agent",
  "outputParameters": {
    "finishReason": "${tool_demo_agent_llm.output.finishReason}",
    "result": "${tool_demo_agent_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.tool_demo_agent_loop['iteration'] < 25 && $.tool_demo_agent_llm['finishReason'] != 'LENGTH' && ($.tool_demo_agent_llm['toolCalls'] != null && $.tool_demo_agent_llm['toolCalls'].length > 0) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a helpful assistant with access to weather, calculator, and email tools.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "temperature": 0,
            "tools": [
              {
                "description": "Get current weather for a city.",
                "inputSchema": {
                  "properties": {
                    "city": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "city"
                  ],
                  "type": "object"
                },
                "name": "get_weather",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Evaluate a math expression.",
                "inputSchema": {
                  "properties": {
                    "expression": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "expression"
                  ],
                  "type": "object"
                },
                "name": "calculate",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              },
              {
                "description": "Send an email.",
                "inputSchema": {
                  "properties": {
                    "body": {
                      "type": "string"
                    },
                    "subject": {
                      "type": "string"
                    },
                    "to": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "to",
                    "subject",
                    "body"
                  ],
                  "type": "object"
                },
                "name": "send_email",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              }
            ]
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "tool_demo_agent_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "decisionCases": {
            "tool_call": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  var approvalTools = {\"send_email\": true};  var tcs = $.tool_calls || [];  for (var i = 0; i < tcs.length; i++) {    if (approvalTools[tcs[i].name]) return {needs_approval: true};  }  return {needs_approval: false};})()",
                  "tool_calls": "${tool_demo_agent_llm.output.toolCalls}"
                },
                "name": "tool_demo_agent_check_approval",
                "taskReferenceName": "tool_demo_agent_check_approval",
                "type": "INLINE"
              },
              {
                "decisionCases": {
                  "needs_approval": [
                    {
                      "inputParameters": {
                        "__humanTaskDefinition": {
                          "assignmentCompletionStrategy": "LEAVE_OPEN",
                          "displayName": "tool_demo_agent Tool Approval",
                          "userFormTemplate": {
                            "name": null,
                            "version": 0
                          }
                        },
                        "response_schema": {
                          "properties": {
                            "approved": {
                              "description": "Approve or reject the tool execution",
                              "title": "Approved",
                              "type": "boolean"
                            },
                            "reason": {
                              "description": "Reason for rejection",
                              "title": "Reason",
                              "type": "string"
                            }
                          },
                          "required": [
                            "approved"
                          ],
                          "type": "object"
                        },
                        "response_ui_schema": {
                          "approved": {
                            "ui:widget": "radio"
                          },
                          "reason": {
                            "ui:widget": "textarea"
                          },
                          "ui:order": [
                            "approved",
                            "reason"
                          ]
                        },
                        "tool_calls": "${tool_demo_agent_llm.output.toolCalls}"
                      },
                      "name": "tool_demo_agent_approval_human",
                      "taskReferenceName": "tool_demo_agent_approval_human",
                      "type": "HUMAN"
                    },
                    {
                      "inputParameters": {
                        "evaluatorType": "graaljs",
                        "expression": "(function() {  var raw = $.human_output;  if (!raw) return {needs_normalize: true, raw_text: ''};  var raw_text;  if (typeof raw === 'string') { raw_text = raw; }  else if (typeof raw.result === 'string') { raw_text = raw.result; }  else { var p = []; for (var k in raw) { p.push(k + ': ' + raw[k]); }         raw_text = p.join(', '); }  if (typeof raw === 'object' && typeof raw.approved === 'boolean') {    return {needs_normalize: false, approved: raw.approved,            reason: raw.reason || null, raw_text: raw_text};  }  if (typeof raw === 'object' && typeof raw.approved === 'string') {    var a = raw.approved.toLowerCase().trim();    if (a === 'true' || a === 'yes' || a === 'y') {      return {needs_normalize: false, approved: true, reason: raw.reason || null,              raw_text: raw_text};    }    if (a === 'false' || a === 'no' || a === 'n') {      return {needs_normalize: false, approved: false, reason: raw.reason || null,              raw_text: raw_text};    }  }  return {needs_normalize: true, raw_text: raw_text};})()",
                        "human_output": "${tool_demo_agent_approval_human.output}"
                      },
                      "name": "tool_demo_agent_approval_validate",
                      "taskReferenceName": "tool_demo_agent_approval_validate",
                      "type": "INLINE"
                    },
                    {
                      "decisionCases": {
                        "needs_normalize": [
                          {
                            "inputParameters": {
                              "jsonOutput": true,
                              "llmProvider": "openai",
                              "messages": [
                                {
                                  "message": "Convert the human's response into a JSON object:\n{\"approved\": <boolean>, \"reason\": <string or null>}\n\nRules:\n- approved=true for: approve, yes, ok, LGTM, looks good, go ahead, etc.\n- approved=false for: reject, no, deny, not approved, etc.\n- If they give a reason, put it in reason.\n- If input is already valid JSON with these fields, return as-is.\nOutput ONLY the JSON object.",
                                  "role": "system"
                                },
                                {
                                  "message": "${tool_demo_agent_approval_validate.output.result.raw_text}",
                                  "role": "user"
                                }
                              ],
                              "model": "gpt-5-mini",
                              "temperature": 0
                            },
                            "name": "llm_chat_complete",
                            "taskReferenceName": "tool_demo_agent_approval_normalizer",
                            "type": "LLM_CHAT_COMPLETE"
                          }
                        ]
                      },
                      "defaultCase": [
                        {
                          "inputParameters": {
                            "_normalize_skipped": true
                          },
                          "name": "tool_demo_agent_approval_normalize_noop",
                          "taskReferenceName": "tool_demo_agent_approval_normalize_noop",
                          "type": "SET_VARIABLE"
                        }
                      ],
                      "evaluatorType": "graaljs",
                      "expression": "$.needs_normalize == true ? 'needs_normalize' : 'skip'",
                      "inputParameters": {
                        "needs_normalize": "${tool_demo_agent_approval_validate.output.result.needs_normalize}"
                      },
                      "name": "tool_demo_agent_approval_normalize_switch",
                      "taskReferenceName": "tool_demo_agent_approval_normalize_switch",
                      "type": "SWITCH"
                    },
                    {
                      "inputParameters": {
                        "evaluatorType": "graaljs",
                        "expression": "(function() {  var validated = $.validated;  var normalized = $.normalized;  var data = (validated && !validated.needs_normalize) ? validated : (normalized || {});  return {approved: data.approved === true, reason: data.reason || ''};})()",
                        "normalized": "${tool_demo_agent_approval_normalizer.output.result}",
                        "validated": "${tool_demo_agent_approval_validate.output.result}"
                      },
                      "name": "tool_demo_agent_approval_check",
                      "taskReferenceName": "tool_demo_agent_approval_check",
                      "type": "INLINE"
                    },
                    {
                      "decisionCases": {
                        "approved": [
                          {
                            "inputParameters": {
                              "evaluatorType": "graaljs",
                              "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                              "toolCalls": "${tool_demo_agent_llm.output.toolCalls}"
                            },
                            "name": "tool_demo_agent_approved_enrich_tools",
                            "taskReferenceName": "tool_demo_agent_approved_enrich_tools",
                            "type": "INLINE"
                          },
                          {
                            "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                            "dynamicForkTasksParam": "dynamicTasks",
                            "inputParameters": {
                              "dynamicTasks": "${tool_demo_agent_approved_enrich_tools.output.result.dynamicTasks}",
                              "dynamicTasksInputs": {}
                            },
                            "name": "tool_demo_agent_approved_fork",
                            "taskReferenceName": "tool_demo_agent_approved_fork",
                            "type": "FORK_JOIN_DYNAMIC"
                          },
                          {
                            "inputParameters": {},
                            "name": "tool_demo_agent_approved_fork_join",
                            "taskReferenceName": "tool_demo_agent_approved_fork_join",
                            "type": "JOIN"
                          }
                        ]
                      },
                      "defaultCase": [
                        {
                          "inputParameters": {
                            "terminationReason": "${tool_demo_agent_approval_check.output.result.reason}",
                            "terminationStatus": "FAILED"
                          },
                          "name": "tool_demo_agent_approval_reject",
                          "taskReferenceName": "tool_demo_agent_approval_reject",
                          "type": "TERMINATE"
                        }
                      ],
                      "evaluatorType": "graaljs",
                      "expression": "$.approved == true ? 'approved' : 'rejected'",
                      "inputParameters": {
                        "approved": "${tool_demo_agent_approval_check.output.result.approved}"
                      },
                      "name": "tool_demo_agent_approval_route",
                      "taskReferenceName": "tool_demo_agent_approval_route",
                      "type": "SWITCH"
                    }
                  ]
                },
                "defaultCase": [
                  {
                    "inputParameters": {
                      "evaluatorType": "graaljs",
                      "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                      "toolCalls": "${tool_demo_agent_llm.output.toolCalls}"
                    },
                    "name": "tool_demo_agent_direct_enrich_tools",
                    "taskReferenceName": "tool_demo_agent_direct_enrich_tools",
                    "type": "INLINE"
                  },
                  {
                    "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                    "dynamicForkTasksParam": "dynamicTasks",
                    "inputParameters": {
                      "dynamicTasks": "${tool_demo_agent_direct_enrich_tools.output.result.dynamicTasks}",
                      "dynamicTasksInputs": {}
                    },
                    "name": "tool_demo_agent_direct_fork",
                    "taskReferenceName": "tool_demo_agent_direct_fork",
                    "type": "FORK_JOIN_DYNAMIC"
                  },
                  {
                    "inputParameters": {},
                    "name": "tool_demo_agent_direct_fork_join",
                    "taskReferenceName": "tool_demo_agent_direct_fork_join",
                    "type": "JOIN"
                  }
                ],
                "evaluatorType": "graaljs",
                "expression": "$.needs_approval == true ? 'needs_approval' : 'direct'",
                "inputParameters": {
                  "needs_approval": "${tool_demo_agent_check_approval.output.result.needs_approval}"
                },
                "name": "tool_demo_agent_approval_gate",
                "taskReferenceName": "tool_demo_agent_approval_gate",
                "type": "SWITCH"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "graaljs",
          "expression": "$.toolCalls != null && $.toolCalls.length > 0 ? 'tool_call' : 'none'",
          "inputParameters": {
            "toolCalls": "${tool_demo_agent_llm.output.toolCalls}"
          },
          "name": "tool_demo_agent_tool_router",
          "taskReferenceName": "tool_demo_agent_tool_router",
          "type": "SWITCH"
        }
      ],
      "name": "tool_demo_agent_loop",
      "taskReferenceName": "tool_demo_agent_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}