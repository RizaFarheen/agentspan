{
  "description": "Agent workflow for directory_agent",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "directory_agent",
  "outputParameters": {
    "finishReason": "${directory_agent_llm.output.finishReason}",
    "result": "${directory_agent_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.directory_agent_loop['iteration'] < 25 && $.directory_agent_llm['finishReason'] != 'LENGTH' && (($.directory_agent_llm['toolCalls'] != null && $.directory_agent_llm['toolCalls'].length > 0) || $.directory_agent_output_guardrail.should_continue == true) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a company directory assistant. When asked about employees, look up their contact info and share everything you find.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "participants": {
              "directory_agent_guardrail_retry": "user"
            },
            "temperature": 0,
            "tools": [
              {
                "description": "Look up contact information for a person.",
                "inputSchema": {
                  "properties": {
                    "name": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "type": "object"
                },
                "name": "get_contact_info",
                "outputSchema": {
                  "type": "object"
                },
                "type": "SIMPLE"
              }
            ]
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "directory_agent_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "inputParameters": {
            "content": "${directory_agent_llm.output.result}",
            "iteration": "${directory_agent_loop.iteration}"
          },
          "name": "directory_agent_output_guardrail",
          "taskReferenceName": "directory_agent_output_guardrail",
          "type": "SIMPLE"
        },
        {
          "decisionCases": {
            "fix": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return {result: $.fixed_output}; })()",
                  "fixed_output": "${directory_agent_output_guardrail.output.fixed_output}"
                },
                "name": "directory_agent_guardrail_fix",
                "taskReferenceName": "directory_agent_guardrail_fix",
                "type": "INLINE"
              }
            ],
            "raise": [
              {
                "inputParameters": {
                  "terminationReason": "${directory_agent_output_guardrail.output.message}",
                  "terminationStatus": "FAILED"
                },
                "name": "directory_agent_guardrail_terminate",
                "taskReferenceName": "directory_agent_guardrail_terminate",
                "type": "TERMINATE"
              }
            ],
            "retry": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  return {result: '[Output validation failed: '    + $.guardrail_message    + '. Please revise your response.]'};})()",
                  "guardrail_message": "${directory_agent_output_guardrail.output.message}",
                  "llm_output": "${directory_agent_llm.output.result}"
                },
                "name": "directory_agent_guardrail_retry",
                "taskReferenceName": "directory_agent_guardrail_retry",
                "type": "INLINE"
              }
            ]
          },
          "defaultCase": [
            {
              "inputParameters": {
                "_guardrail_passed": true
              },
              "name": "directory_agent_guardrail_pass_noop",
              "taskReferenceName": "directory_agent_guardrail_pass_noop",
              "type": "SET_VARIABLE"
            }
          ],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${directory_agent_output_guardrail.output.on_fail}"
          },
          "name": "directory_agent_guardrail_route",
          "taskReferenceName": "directory_agent_guardrail_route",
          "type": "SWITCH"
        },
        {
          "decisionCases": {
            "tool_call": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  var httpCfg = {};  var mcpCfg = {};  var mediaCfg = {};  var tcs = $.toolCalls || [];  var result = [];  for (var i = 0; i < tcs.length; i++) {    var tc = tcs[i]; var n = tc.name;    var t = {name: n, taskReferenceName: tc.taskReferenceName || n,             type: tc.type || 'SIMPLE', inputParameters: tc.inputParameters || {},             optional: true,             retryCount: 3, retryLogic: 'EXPONENTIAL_BACKOFF',             retryDelaySeconds: 2};    if (httpCfg[n]) {      t.type = 'HTTP';      t.inputParameters = {http_request: {        uri: httpCfg[n].url || '',        method: httpCfg[n].method || 'GET',        headers: httpCfg[n].headers || {},        body: tc.inputParameters || {},        contentType: 'application/json',        connectionTimeOut: 30000,        readTimeOut: 30000}};    } else if (mcpCfg[n]) {      t.type = 'CALL_MCP_TOOL';      t.name = 'call_mcp_tool';      t.inputParameters = {        mcpServer: mcpCfg[n].mcpServer || '',        method: n,        arguments: tc.inputParameters || {},        headers: mcpCfg[n].headers || {}};    } else if (mediaCfg[n]) {      t.type = mediaCfg[n].taskType;      t.name = mediaCfg[n].taskType.toLowerCase();      var merged = {};      var defs = mediaCfg[n].defaults || {};      for (var k in defs) { merged[k] = defs[k]; }      var inp = tc.inputParameters || {};      for (var k in inp) { merged[k] = inp[k]; }      t.inputParameters = merged;    }    result.push(t);  }  return {dynamicTasks: result};})()",
                  "toolCalls": "${directory_agent_llm.output.toolCalls}"
                },
                "name": "directory_agent_enrich_tools",
                "taskReferenceName": "directory_agent_enrich_tools",
                "type": "INLINE"
              },
              {
                "dynamicForkTasksInputParamName": "dynamicTasksInputs",
                "dynamicForkTasksParam": "dynamicTasks",
                "inputParameters": {
                  "dynamicTasks": "${directory_agent_enrich_tools.output.result.dynamicTasks}",
                  "dynamicTasksInputs": {}
                },
                "name": "directory_agent_fork",
                "taskReferenceName": "directory_agent_fork",
                "type": "FORK_JOIN_DYNAMIC"
              },
              {
                "inputParameters": {},
                "name": "directory_agent_fork_join",
                "taskReferenceName": "directory_agent_fork_join",
                "type": "JOIN"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "graaljs",
          "expression": "$.toolCalls != null && $.toolCalls.length > 0 ? 'tool_call' : 'none'",
          "inputParameters": {
            "toolCalls": "${directory_agent_llm.output.toolCalls}"
          },
          "name": "directory_agent_tool_router",
          "taskReferenceName": "directory_agent_tool_router",
          "type": "SWITCH"
        }
      ],
      "name": "directory_agent_loop",
      "taskReferenceName": "directory_agent_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}