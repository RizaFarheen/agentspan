{
  "description": "Swarm orchestration: support",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "support",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "active_agent": "0",
        "conversation": "${workflow.input.prompt}"
      },
      "name": "support_init",
      "taskReferenceName": "support_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.support_loop['iteration'] < 3 ) { true; } else { false; }",
      "loopOver": [
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a refund specialist. Process refund requests, check eligibility, and guide customers through the refund process. Be empathetic and clear.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "support_agent_0_refund_specialist",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[refund_specialist]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${support_agent_0_refund_specialist.output.result}"
                },
                "name": "support_concat_0",
                "taskReferenceName": "support_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${support_concat_0.output.result}"
                },
                "name": "support_set_0",
                "taskReferenceName": "support_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a technical support specialist. Diagnose technical issues, provide troubleshooting steps, and escalate if needed.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "support_agent_1_tech_support",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[tech_support]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${support_agent_1_tech_support.output.result}"
                },
                "name": "support_concat_1",
                "taskReferenceName": "support_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${support_concat_1.output.result}"
                },
                "name": "support_set_1",
                "taskReferenceName": "support_set_1",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${workflow.variables.active_agent}"
          },
          "name": "support_switch",
          "taskReferenceName": "support_switch",
          "type": "SWITCH"
        },
        {
          "inputParameters": {
            "active_agent": "${workflow.variables.active_agent}",
            "conversation": "${workflow.variables.conversation}",
            "result": "${workflow.variables.conversation}"
          },
          "name": "support_handoff_check",
          "taskReferenceName": "support_handoff_check",
          "type": "SIMPLE"
        },
        {
          "inputParameters": {
            "active_agent": "${support_handoff_check.output.active_agent}"
          },
          "name": "support_update_active",
          "taskReferenceName": "support_update_active",
          "type": "SET_VARIABLE"
        }
      ],
      "name": "support_loop",
      "taskReferenceName": "support_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}