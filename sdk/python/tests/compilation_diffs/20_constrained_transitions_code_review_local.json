{
  "description": "Round-Robin discussion: code_review",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "code_review",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "conversation": "${workflow.input.prompt}",
        "last_agent": "0"
      },
      "name": "code_review_init",
      "taskReferenceName": "code_review_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.code_review_loop['iteration'] < 6 ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "evaluatorType": "graaljs",
            "expression": "(function() {  var allowed = {\"0\": [1], \"1\": [0, 2], \"2\": [0]};  var last = String($.last_agent);  var candidates = allowed[last];  if (!candidates) candidates = Array.from(Array(3).keys());  var idx = $.iteration % candidates.length;  return String(candidates[idx]);})()",
            "iteration": "${code_review_loop.iteration}",
            "last_agent": "${workflow.variables.last_agent}"
          },
          "name": "code_review_select",
          "taskReferenceName": "code_review_select",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a software developer. Write or revise code based on feedback. Keep responses focused on code changes.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "code_review_agent_0_developer",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[developer]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${code_review_agent_0_developer.output.result}"
                },
                "name": "code_review_concat_0",
                "taskReferenceName": "code_review_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${code_review_concat_0.output.result}",
                  "last_agent": "0"
                },
                "name": "code_review_set_0",
                "taskReferenceName": "code_review_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a code reviewer. Review the developer's code for bugs, style, and best practices. Provide specific, actionable feedback.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "code_review_agent_1_reviewer",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[reviewer]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${code_review_agent_1_reviewer.output.result}"
                },
                "name": "code_review_concat_1",
                "taskReferenceName": "code_review_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${code_review_concat_1.output.result}",
                  "last_agent": "1"
                },
                "name": "code_review_set_1",
                "taskReferenceName": "code_review_set_1",
                "type": "SET_VARIABLE"
              }
            ],
            "2": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are the tech lead. Review the code and feedback. Either approve the code or request revisions with specific guidance.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "code_review_agent_2_approver",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[approver]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${code_review_agent_2_approver.output.result}"
                },
                "name": "code_review_concat_2",
                "taskReferenceName": "code_review_concat_2",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${code_review_concat_2.output.result}",
                  "last_agent": "2"
                },
                "name": "code_review_set_2",
                "taskReferenceName": "code_review_set_2",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${code_review_select.output.result}"
          },
          "name": "code_review_switch",
          "taskReferenceName": "code_review_switch",
          "type": "SWITCH"
        }
      ],
      "name": "code_review_loop",
      "taskReferenceName": "code_review_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}