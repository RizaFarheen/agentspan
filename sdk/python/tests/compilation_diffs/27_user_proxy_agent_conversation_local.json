{
  "description": "Round-Robin discussion: pair_programming",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "pair_programming",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "conversation": "${workflow.input.prompt}"
      },
      "name": "pair_programming_init",
      "taskReferenceName": "pair_programming_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.pair_programming_loop['iteration'] < 4 ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "evaluatorType": "graaljs",
            "expression": "(function() { return String($.iteration % 2); })()",
            "iteration": "${pair_programming_loop.iteration}"
          },
          "name": "pair_programming_select",
          "taskReferenceName": "pair_programming_select",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You represent the human user in this conversation. Relay the human's input exactly as provided.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-4o"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "pair_programming_agent_0_human",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[human]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${pair_programming_agent_0_human.output.result}"
                },
                "name": "pair_programming_concat_0",
                "taskReferenceName": "pair_programming_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${pair_programming_concat_0.output.result}"
                },
                "name": "pair_programming_set_0",
                "taskReferenceName": "pair_programming_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a helpful coding assistant. Help the user write Python code. Ask clarifying questions when needed.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "pair_programming_agent_1_assistant",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[assistant]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${pair_programming_agent_1_assistant.output.result}"
                },
                "name": "pair_programming_concat_1",
                "taskReferenceName": "pair_programming_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${pair_programming_concat_1.output.result}"
                },
                "name": "pair_programming_set_1",
                "taskReferenceName": "pair_programming_set_1",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${pair_programming_select.output.result}"
          },
          "name": "pair_programming_switch",
          "taskReferenceName": "pair_programming_switch",
          "type": "SWITCH"
        }
      ],
      "name": "pair_programming_loop",
      "taskReferenceName": "pair_programming_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}