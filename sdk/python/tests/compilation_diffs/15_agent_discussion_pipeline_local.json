{
  "description": "Sequential pipeline: discussion_summarizer",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "discussion_summarizer",
  "outputParameters": {
    "result": "${discussion_summarizer_step_1_summarizer.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "media": "${workflow.input.media}",
        "prompt": "${workflow.input.prompt}"
      },
      "name": "discussion_summarizer_step_0_discussion",
      "subWorkflowParam": {
        "name": "discussion",
        "version": 1,
        "workflowDefinition": {
          "description": "Round-Robin discussion: discussion",
          "enforceSchema": false,
          "failureWorkflow": "",
          "inputParameters": [
            "prompt",
            "session_id",
            "media"
          ],
          "inputTemplate": {},
          "name": "discussion",
          "outputParameters": {
            "result": "${workflow.variables.conversation}"
          },
          "schemaVersion": 2,
          "tasks": [
            {
              "inputParameters": {
                "conversation": "${workflow.input.prompt}"
              },
              "name": "discussion_init",
              "taskReferenceName": "discussion_init",
              "type": "SET_VARIABLE"
            },
            {
              "inputParameters": {},
              "loopCondition": "if ( $.discussion_loop['iteration'] < 6 ) { true; } else { false; }",
              "loopOver": [
                {
                  "inputParameters": {
                    "evaluatorType": "graaljs",
                    "expression": "(function() { return String($.iteration % 2); })()",
                    "iteration": "${discussion_loop.iteration}"
                  },
                  "name": "discussion_select",
                  "taskReferenceName": "discussion_select",
                  "type": "INLINE"
                },
                {
                  "decisionCases": {
                    "0": [
                      {
                        "inputParameters": {
                          "llmProvider": "openai",
                          "messages": [
                            {
                              "message": "You are an optimistic technologist debating a topic. Argue FOR the topic. Keep your response to 2-3 concise paragraphs. Acknowledge the other side's points before making your case.",
                              "role": "system"
                            },
                            {
                              "message": "${workflow.variables.conversation}",
                              "role": "user"
                            }
                          ],
                          "model": "gpt-5-mini"
                        },
                        "name": "llm_chat_complete",
                        "taskReferenceName": "discussion_agent_0_optimist",
                        "type": "LLM_CHAT_COMPLETE"
                      },
                      {
                        "inputParameters": {
                          "evaluatorType": "graaljs",
                          "expression": "(function() { return $.prev + '\\n\\n[optimist]: ' + $.response; })()",
                          "prev": "${workflow.variables.conversation}",
                          "response": "${discussion_agent_0_optimist.output.result}"
                        },
                        "name": "discussion_concat_0",
                        "taskReferenceName": "discussion_concat_0",
                        "type": "INLINE"
                      },
                      {
                        "inputParameters": {
                          "conversation": "${discussion_concat_0.output.result}"
                        },
                        "name": "discussion_set_0",
                        "taskReferenceName": "discussion_set_0",
                        "type": "SET_VARIABLE"
                      }
                    ],
                    "1": [
                      {
                        "inputParameters": {
                          "llmProvider": "openai",
                          "messages": [
                            {
                              "message": "You are a thoughtful skeptic debating a topic. Raise concerns and argue AGAINST the topic. Keep your response to 2-3 concise paragraphs. Acknowledge the other side's points before making your case.",
                              "role": "system"
                            },
                            {
                              "message": "${workflow.variables.conversation}",
                              "role": "user"
                            }
                          ],
                          "model": "gpt-5-mini"
                        },
                        "name": "llm_chat_complete",
                        "taskReferenceName": "discussion_agent_1_skeptic",
                        "type": "LLM_CHAT_COMPLETE"
                      },
                      {
                        "inputParameters": {
                          "evaluatorType": "graaljs",
                          "expression": "(function() { return $.prev + '\\n\\n[skeptic]: ' + $.response; })()",
                          "prev": "${workflow.variables.conversation}",
                          "response": "${discussion_agent_1_skeptic.output.result}"
                        },
                        "name": "discussion_concat_1",
                        "taskReferenceName": "discussion_concat_1",
                        "type": "INLINE"
                      },
                      {
                        "inputParameters": {
                          "conversation": "${discussion_concat_1.output.result}"
                        },
                        "name": "discussion_set_1",
                        "taskReferenceName": "discussion_set_1",
                        "type": "SET_VARIABLE"
                      }
                    ]
                  },
                  "defaultCase": [],
                  "evaluatorType": "value-param",
                  "expression": "switchCaseValue",
                  "inputParameters": {
                    "switchCaseValue": "${discussion_select.output.result}"
                  },
                  "name": "discussion_switch",
                  "taskReferenceName": "discussion_switch",
                  "type": "SWITCH"
                }
              ],
              "name": "discussion_loop",
              "taskReferenceName": "discussion_loop",
              "type": "DO_WHILE"
            }
          ],
          "timeoutSeconds": 60,
          "variables": {},
          "version": 1,
          "workflowStatusListenerEnabled": false
        }
      },
      "taskReferenceName": "discussion_summarizer_step_0_discussion",
      "type": "SUB_WORKFLOW"
    },
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "You are a neutral moderator. You have just observed a debate between an optimist and a skeptic. Summarize the key arguments from both sides and provide a balanced conclusion. Structure your response with: Key Arguments For, Key Arguments Against, and Balanced Conclusion.",
            "role": "system"
          },
          {
            "message": "${discussion_summarizer_step_0_discussion.output.result}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "discussion_summarizer_step_1_summarizer",
      "type": "LLM_CHAT_COMPLETE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}