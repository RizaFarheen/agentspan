{
  "description": "Agent workflow for essay_writer",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "essay_writer",
  "outputParameters": {
    "finishReason": "${essay_writer_llm.output.finishReason}",
    "result": "${essay_writer_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.essay_writer_loop['iteration'] < 25 && $.essay_writer_llm['finishReason'] != 'LENGTH' && ($.essay_writer_regex_guardrail_no_lists.result.should_continue == true || $.essay_writer_output_guardrail.should_continue == true) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a concise essay writer. Answer the user's question in well-structured prose paragraphs. Do NOT use bullet points or numbered lists.",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "participants": {
              "essay_writer_guardrail_retry_0": "user",
              "essay_writer_guardrail_retry_1": "user"
            }
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "essay_writer_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "inputParameters": {
            "content": "${essay_writer_llm.output.result}",
            "evaluatorType": "graaljs",
            "expression": "(function() {  var content = $.content;  var iteration = $.iteration;  var patterns = [\"^\\\\s*[-*]\\\\s\", \"^\\\\s*\\\\d+\\\\.\\\\s\"];  var mode = \"block\";  var on_fail = \"retry\";  var message = \"Do not use bullet points or numbered lists. Write in flowing prose paragraphs instead.\";  var max_retries = 3;  var guardrail_name = \"no_lists\";  var matched = false;  for (var i = 0; i < patterns.length; i++) {    if (new RegExp(patterns[i]).test(content)) { matched = true; break; }  }  var failed = (mode === 'block' && matched) || (mode === 'allow' && !matched);  if (!failed) {    return {passed: true, message: '', on_fail: 'pass',            fixed_output: null, guardrail_name: '', should_continue: false};  }  var actual_fail = (on_fail === 'retry' && iteration >= max_retries) ? 'raise' : on_fail;  return {passed: false, message: message, on_fail: actual_fail,          fixed_output: null, guardrail_name: guardrail_name,          should_continue: actual_fail === 'retry'};})()",
            "iteration": "${essay_writer_loop.iteration}"
          },
          "name": "essay_writer_regex_guardrail_no_lists",
          "taskReferenceName": "essay_writer_regex_guardrail_no_lists",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "fix": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return {result: $.fixed_output}; })()",
                  "fixed_output": "${essay_writer_regex_guardrail_no_lists.output.result.fixed_output}"
                },
                "name": "essay_writer_guardrail_fix_0",
                "taskReferenceName": "essay_writer_guardrail_fix_0",
                "type": "INLINE"
              }
            ],
            "raise": [
              {
                "inputParameters": {
                  "terminationReason": "${essay_writer_regex_guardrail_no_lists.output.result.message}",
                  "terminationStatus": "FAILED"
                },
                "name": "essay_writer_guardrail_terminate_0",
                "taskReferenceName": "essay_writer_guardrail_terminate_0",
                "type": "TERMINATE"
              }
            ],
            "retry": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  return {result: '[Output validation failed: '    + $.guardrail_message    + '. Please revise your response.]'};})()",
                  "guardrail_message": "${essay_writer_regex_guardrail_no_lists.output.result.message}",
                  "llm_output": "${essay_writer_llm.output.result}"
                },
                "name": "essay_writer_guardrail_retry_0",
                "taskReferenceName": "essay_writer_guardrail_retry_0",
                "type": "INLINE"
              }
            ]
          },
          "defaultCase": [
            {
              "inputParameters": {
                "_guardrail_passed": true
              },
              "name": "essay_writer_guardrail_pass_noop_0",
              "taskReferenceName": "essay_writer_guardrail_pass_noop_0",
              "type": "SET_VARIABLE"
            }
          ],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${essay_writer_regex_guardrail_no_lists.output.result.on_fail}"
          },
          "name": "essay_writer_guardrail_route_0",
          "taskReferenceName": "essay_writer_guardrail_route_0",
          "type": "SWITCH"
        },
        {
          "inputParameters": {
            "content": "${essay_writer_llm.output.result}",
            "iteration": "${essay_writer_loop.iteration}"
          },
          "name": "essay_writer_output_guardrail",
          "taskReferenceName": "essay_writer_output_guardrail",
          "type": "SIMPLE"
        },
        {
          "decisionCases": {
            "fix": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return {result: $.fixed_output}; })()",
                  "fixed_output": "${essay_writer_output_guardrail.output.fixed_output}"
                },
                "name": "essay_writer_guardrail_fix_1",
                "taskReferenceName": "essay_writer_guardrail_fix_1",
                "type": "INLINE"
              }
            ],
            "raise": [
              {
                "inputParameters": {
                  "terminationReason": "${essay_writer_output_guardrail.output.message}",
                  "terminationStatus": "FAILED"
                },
                "name": "essay_writer_guardrail_terminate_1",
                "taskReferenceName": "essay_writer_guardrail_terminate_1",
                "type": "TERMINATE"
              }
            ],
            "retry": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  return {result: '[Output validation failed: '    + $.guardrail_message    + '. Please revise your response.]'};})()",
                  "guardrail_message": "${essay_writer_output_guardrail.output.message}",
                  "llm_output": "${essay_writer_llm.output.result}"
                },
                "name": "essay_writer_guardrail_retry_1",
                "taskReferenceName": "essay_writer_guardrail_retry_1",
                "type": "INLINE"
              }
            ]
          },
          "defaultCase": [
            {
              "inputParameters": {
                "_guardrail_passed": true
              },
              "name": "essay_writer_guardrail_pass_noop_1",
              "taskReferenceName": "essay_writer_guardrail_pass_noop_1",
              "type": "SET_VARIABLE"
            }
          ],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${essay_writer_output_guardrail.output.on_fail}"
          },
          "name": "essay_writer_guardrail_route_1",
          "taskReferenceName": "essay_writer_guardrail_route_1",
          "type": "SWITCH"
        }
      ],
      "name": "essay_writer_loop",
      "taskReferenceName": "essay_writer_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}