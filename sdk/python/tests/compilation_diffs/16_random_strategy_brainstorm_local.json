{
  "description": "Random discussion: brainstorm",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "brainstorm",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "conversation": "${workflow.input.prompt}"
      },
      "name": "brainstorm_init",
      "taskReferenceName": "brainstorm_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.brainstorm_loop['iteration'] < 6 ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "evaluatorType": "graaljs",
            "expression": "(function() { return String(Math.floor(Math.random() * 3)); })()",
            "iteration": "${brainstorm_loop.iteration}"
          },
          "name": "brainstorm_select",
          "taskReferenceName": "brainstorm_select",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a creative thinker. Suggest innovative, unconventional ideas. Keep your response to 2-3 sentences.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "brainstorm_agent_0_creative",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[creative]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${brainstorm_agent_0_creative.output.result}"
                },
                "name": "brainstorm_concat_0",
                "taskReferenceName": "brainstorm_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${brainstorm_concat_0.output.result}"
                },
                "name": "brainstorm_set_0",
                "taskReferenceName": "brainstorm_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a practical thinker. Focus on feasibility and cost-effectiveness. Keep your response to 2-3 sentences.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "brainstorm_agent_1_practical",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[practical]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${brainstorm_agent_1_practical.output.result}"
                },
                "name": "brainstorm_concat_1",
                "taskReferenceName": "brainstorm_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${brainstorm_concat_1.output.result}"
                },
                "name": "brainstorm_set_1",
                "taskReferenceName": "brainstorm_set_1",
                "type": "SET_VARIABLE"
              }
            ],
            "2": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a critical thinker. Identify risks and potential issues. Keep your response to 2-3 sentences.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "brainstorm_agent_2_critical",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[critical]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${brainstorm_agent_2_critical.output.result}"
                },
                "name": "brainstorm_concat_2",
                "taskReferenceName": "brainstorm_concat_2",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${brainstorm_concat_2.output.result}"
                },
                "name": "brainstorm_set_2",
                "taskReferenceName": "brainstorm_set_2",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${brainstorm_select.output.result}"
          },
          "name": "brainstorm_switch",
          "taskReferenceName": "brainstorm_switch",
          "type": "SWITCH"
        }
      ],
      "name": "brainstorm_loop",
      "taskReferenceName": "brainstorm_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}