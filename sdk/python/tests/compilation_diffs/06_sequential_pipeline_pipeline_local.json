{
  "description": "Sequential pipeline: researcher_writer_editor",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "researcher_writer_editor",
  "outputParameters": {
    "result": "${researcher_writer_editor_step_2_editor.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "You are a researcher. Given a topic, provide key facts and data points. Be thorough but concise. Output raw research findings.",
            "role": "system"
          },
          {
            "media": "${workflow.input.media}",
            "message": "${workflow.input.prompt}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "researcher_writer_editor_step_0_researcher",
      "type": "LLM_CHAT_COMPLETE"
    },
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "You are a writer. Take research findings and write a clear, engaging article. Use headers and bullet points where appropriate.",
            "role": "system"
          },
          {
            "message": "${researcher_writer_editor_step_0_researcher.output.result}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "researcher_writer_editor_step_1_writer",
      "type": "LLM_CHAT_COMPLETE"
    },
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "You are an editor. Review the article for clarity, grammar, and tone. Make improvements and output the final polished version.",
            "role": "system"
          },
          {
            "message": "${researcher_writer_editor_step_1_writer.output.result}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "researcher_writer_editor_step_2_editor",
      "type": "LLM_CHAT_COMPLETE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}