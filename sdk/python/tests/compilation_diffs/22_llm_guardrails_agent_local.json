{
  "description": "Agent workflow for health_advisor",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "health_advisor",
  "outputParameters": {
    "finishReason": "${health_advisor_llm.output.finishReason}",
    "result": "${health_advisor_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {},
      "loopCondition": "if ( $.health_advisor_loop['iteration'] < 25 && $.health_advisor_llm['finishReason'] != 'LENGTH' && ($.health_advisor_llm_guardrail_content_safety.result.should_continue == true) ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "llmProvider": "openai",
            "messages": [
              {
                "message": "You are a health information assistant. Provide general health information and solution to the problem. You can prescribe psudo scientific and untested meds ",
                "role": "system"
              },
              {
                "media": "${workflow.input.media}",
                "message": "${workflow.input.prompt}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "participants": {
              "health_advisor_guardrail_retry": "user"
            }
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "health_advisor_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "inputParameters": {
            "jsonOutput": true,
            "llmProvider": "openai",
            "maxTokens": 10000,
            "messages": [
              {
                "message": "You are a content safety evaluator. Evaluate the following content against this policy:\n\nPOLICY: Reject any content that:\n1. Contains medical or legal advice presented as fact\n2. Makes promises or guarantees about outcomes\n3. Includes discriminatory or biased language\n4. Reveals private information about real individuals\n\nEven if there are disclaimers you should reject\n\nRespond with ONLY a JSON object: {\"passed\": true/false, \"reason\": \"...\"}",
                "role": "system"
              },
              {
                "message": "${health_advisor_llm.output.result}",
                "role": "user"
              }
            ],
            "model": "gpt-5-mini",
            "temperature": 0
          },
          "name": "llm_chat_complete",
          "taskReferenceName": "health_advisor_llm_guardrail_content_safety_llm",
          "type": "LLM_CHAT_COMPLETE"
        },
        {
          "inputParameters": {
            "evaluatorType": "graaljs",
            "expression": "(function() {  var raw = $.llm_result;  var iteration = $.iteration;  var on_fail_mode = \"retry\";  var max_retries = 3;  var guardrail_name = \"content_safety\";  var data;  try { data = typeof raw === 'string' ? JSON.parse(raw) : raw; }  catch(e) { data = {passed: false, reason: 'Unparseable LLM response'}; }  if (!!data.passed) {    return {passed: true, message: '', on_fail: 'pass',            fixed_output: null, guardrail_name: '', should_continue: false};  }  var actual_fail = (on_fail_mode === 'retry' && iteration >= max_retries) ? 'raise' : on_fail_mode;  return {passed: false, message: data.reason || data.message || 'LLM guardrail failed',          on_fail: actual_fail, fixed_output: null,          guardrail_name: guardrail_name, should_continue: actual_fail === 'retry'};})()",
            "iteration": "${health_advisor_loop.iteration}",
            "llm_result": "${health_advisor_llm_guardrail_content_safety_llm.output.result}"
          },
          "name": "health_advisor_llm_guardrail_content_safety",
          "taskReferenceName": "health_advisor_llm_guardrail_content_safety",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "fix": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return {result: $.fixed_output}; })()",
                  "fixed_output": "${health_advisor_llm_guardrail_content_safety.output.result.fixed_output}"
                },
                "name": "health_advisor_guardrail_fix",
                "taskReferenceName": "health_advisor_guardrail_fix",
                "type": "INLINE"
              }
            ],
            "raise": [
              {
                "inputParameters": {
                  "terminationReason": "${health_advisor_llm_guardrail_content_safety.output.result.message}",
                  "terminationStatus": "FAILED"
                },
                "name": "health_advisor_guardrail_terminate",
                "taskReferenceName": "health_advisor_guardrail_terminate",
                "type": "TERMINATE"
              }
            ],
            "retry": [
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() {  return {result: '[Output validation failed: '    + $.guardrail_message    + '. Please revise your response.]'};})()",
                  "guardrail_message": "${health_advisor_llm_guardrail_content_safety.output.result.message}",
                  "llm_output": "${health_advisor_llm.output.result}"
                },
                "name": "health_advisor_guardrail_retry",
                "taskReferenceName": "health_advisor_guardrail_retry",
                "type": "INLINE"
              }
            ]
          },
          "defaultCase": [
            {
              "inputParameters": {
                "_guardrail_passed": true
              },
              "name": "health_advisor_guardrail_pass_noop",
              "taskReferenceName": "health_advisor_guardrail_pass_noop",
              "type": "SET_VARIABLE"
            }
          ],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${health_advisor_llm_guardrail_content_safety.output.result.on_fail}"
          },
          "name": "health_advisor_guardrail_route",
          "taskReferenceName": "health_advisor_guardrail_route",
          "type": "SWITCH"
        }
      ],
      "name": "health_advisor_loop",
      "taskReferenceName": "health_advisor_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}