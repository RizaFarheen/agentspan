{
  "description": "Manual selection: editorial_team",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "editorial_team",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "conversation": "${workflow.input.prompt}"
      },
      "name": "editorial_team_init",
      "taskReferenceName": "editorial_team_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.editorial_team_loop['iteration'] < 3 ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "__humanTaskDefinition": {
              "assignmentCompletionStrategy": "LEAVE_OPEN",
              "displayName": "editorial_team: Select next agent",
              "userFormTemplate": {
                "name": null,
                "version": 0
              }
            },
            "agent_options": {
              "editor": "1",
              "fact_checker": "2",
              "writer": "0"
            },
            "conversation": "${workflow.variables.conversation}"
          },
          "name": "editorial_team_pick_agent",
          "taskReferenceName": "editorial_team_pick_agent",
          "type": "HUMAN"
        },
        {
          "inputParameters": {
            "human_output": "${editorial_team_pick_agent.output}"
          },
          "name": "editorial_team_process_selection",
          "taskReferenceName": "editorial_team_process_selection",
          "type": "SIMPLE"
        },
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a creative writer. Expand on ideas with vivid prose.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "editorial_team_agent_0_writer",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[writer]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${editorial_team_agent_0_writer.output.result}"
                },
                "name": "editorial_team_concat_0",
                "taskReferenceName": "editorial_team_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${editorial_team_concat_0.output.result}"
                },
                "name": "editorial_team_set_0",
                "taskReferenceName": "editorial_team_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a strict editor. Improve clarity, fix issues, tighten prose.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "editorial_team_agent_1_editor",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[editor]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${editorial_team_agent_1_editor.output.result}"
                },
                "name": "editorial_team_concat_1",
                "taskReferenceName": "editorial_team_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${editorial_team_concat_1.output.result}"
                },
                "name": "editorial_team_set_1",
                "taskReferenceName": "editorial_team_set_1",
                "type": "SET_VARIABLE"
              }
            ],
            "2": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You verify claims and flag anything inaccurate or unsupported.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "editorial_team_agent_2_fact_checker",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[fact_checker]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${editorial_team_agent_2_fact_checker.output.result}"
                },
                "name": "editorial_team_concat_2",
                "taskReferenceName": "editorial_team_concat_2",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${editorial_team_concat_2.output.result}"
                },
                "name": "editorial_team_set_2",
                "taskReferenceName": "editorial_team_set_2",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${editorial_team_process_selection.output.selected}"
          },
          "name": "editorial_team_switch",
          "taskReferenceName": "editorial_team_switch",
          "type": "SWITCH"
        }
      ],
      "name": "editorial_team_loop",
      "taskReferenceName": "editorial_team_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}