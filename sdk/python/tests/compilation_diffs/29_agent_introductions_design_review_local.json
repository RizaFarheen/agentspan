{
  "description": "Round-Robin discussion: design_review",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "design_review",
  "outputParameters": {
    "result": "${workflow.variables.conversation}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "conversation": "[architect]: I am the Software Architect. I focus on system design, scalability, and technical trade-offs. I'll evaluate proposals from an architecture perspective.\n[security_engineer]: I am the Security Engineer. I focus on threat modeling, authentication, authorization, and data protection. I'll flag any security concerns.\n[product_manager]: I am the Product Manager. I focus on user needs, business value, and delivery timelines. I'll ensure we stay focused on what matters to customers.\n\n${workflow.input.prompt}"
      },
      "name": "design_review_init",
      "taskReferenceName": "design_review_init",
      "type": "SET_VARIABLE"
    },
    {
      "inputParameters": {},
      "loopCondition": "if ( $.design_review_loop['iteration'] < 6 ) { true; } else { false; }",
      "loopOver": [
        {
          "inputParameters": {
            "evaluatorType": "graaljs",
            "expression": "(function() { return String($.iteration % 3); })()",
            "iteration": "${design_review_loop.iteration}"
          },
          "name": "design_review_select",
          "taskReferenceName": "design_review_select",
          "type": "INLINE"
        },
        {
          "decisionCases": {
            "0": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a software architect. Focus on system design, scalability, and architectural patterns. Keep responses to 2-3 paragraphs.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "design_review_agent_0_architect",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[architect]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${design_review_agent_0_architect.output.result}"
                },
                "name": "design_review_concat_0",
                "taskReferenceName": "design_review_concat_0",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${design_review_concat_0.output.result}"
                },
                "name": "design_review_set_0",
                "taskReferenceName": "design_review_set_0",
                "type": "SET_VARIABLE"
              }
            ],
            "1": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a security engineer. Focus on security implications, vulnerabilities, and best practices. Keep responses to 2-3 paragraphs.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "design_review_agent_1_security_engineer",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[security_engineer]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${design_review_agent_1_security_engineer.output.result}"
                },
                "name": "design_review_concat_1",
                "taskReferenceName": "design_review_concat_1",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${design_review_concat_1.output.result}"
                },
                "name": "design_review_set_1",
                "taskReferenceName": "design_review_set_1",
                "type": "SET_VARIABLE"
              }
            ],
            "2": [
              {
                "inputParameters": {
                  "llmProvider": "openai",
                  "messages": [
                    {
                      "message": "You are a product manager. Focus on user needs, business value, and prioritization. Keep responses to 2-3 paragraphs.",
                      "role": "system"
                    },
                    {
                      "message": "${workflow.variables.conversation}",
                      "role": "user"
                    }
                  ],
                  "model": "gpt-5-mini"
                },
                "name": "llm_chat_complete",
                "taskReferenceName": "design_review_agent_2_product_manager",
                "type": "LLM_CHAT_COMPLETE"
              },
              {
                "inputParameters": {
                  "evaluatorType": "graaljs",
                  "expression": "(function() { return $.prev + '\\n\\n[product_manager]: ' + $.response; })()",
                  "prev": "${workflow.variables.conversation}",
                  "response": "${design_review_agent_2_product_manager.output.result}"
                },
                "name": "design_review_concat_2",
                "taskReferenceName": "design_review_concat_2",
                "type": "INLINE"
              },
              {
                "inputParameters": {
                  "conversation": "${design_review_concat_2.output.result}"
                },
                "name": "design_review_set_2",
                "taskReferenceName": "design_review_set_2",
                "type": "SET_VARIABLE"
              }
            ]
          },
          "defaultCase": [],
          "evaluatorType": "value-param",
          "expression": "switchCaseValue",
          "inputParameters": {
            "switchCaseValue": "${design_review_select.output.result}"
          },
          "name": "design_review_switch",
          "taskReferenceName": "design_review_switch",
          "type": "SWITCH"
        }
      ],
      "name": "design_review_loop",
      "taskReferenceName": "design_review_loop",
      "type": "DO_WHILE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}