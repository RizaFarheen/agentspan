{
  "description": "Agent workflow for chatbot",
  "enforceSchema": false,
  "failureWorkflow": "",
  "inputParameters": [
    "prompt",
    "session_id",
    "media"
  ],
  "inputTemplate": {},
  "name": "chatbot",
  "outputParameters": {
    "finishReason": "${chatbot_llm.output.finishReason}",
    "result": "${chatbot_llm.output.result}"
  },
  "schemaVersion": 2,
  "tasks": [
    {
      "inputParameters": {
        "llmProvider": "openai",
        "messages": [
          {
            "message": "Have a conversation. Say GOODBYE when you're finished.",
            "role": "system"
          },
          {
            "media": "${workflow.input.media}",
            "message": "${workflow.input.prompt}",
            "role": "user"
          }
        ],
        "model": "gpt-5-mini"
      },
      "name": "llm_chat_complete",
      "taskReferenceName": "chatbot_llm",
      "type": "LLM_CHAT_COMPLETE"
    }
  ],
  "timeoutSeconds": 60,
  "variables": {},
  "version": 1,
  "workflowStatusListenerEnabled": false
}